generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["app"]
}

model User {
  id                                                                          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                                                       String                       @unique
  passwordHash                                                                String                       @map("password_hash")
  fullName                                                                    String                       @map("full_name")
  preferredCurrency                                                           String                       @default("CAD") @map("preferred_currency") @db.VarChar(3)
  locale                                                                      String                       @default("en-CA")
  timezone                                                                    String                       @default("America/Toronto")
  status                                                                      user_status                  @default(active)
  createdAt                                                                   DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                                                                   DateTime                     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt                                                                   DateTime?                    @map("deleted_at") @db.Timestamptz(6)
  assets                                                                      assets[]
  auth_sessions                                                               auth_sessions[]
  budget_assignment_events_budget_assignment_events_created_by_user_idTousers budget_assignment_events[]   @relation("budget_assignment_events_created_by_user_idTousers")
  budget_assignment_events_budget_assignment_events_user_idTousers            budget_assignment_events[]   @relation("budget_assignment_events_user_idTousers")
  budget_months                                                               budget_months[]
  budgets                                                                     Budget?
  categories                                                                  categories[]
  category_groups                                                             category_groups[]
  category_months                                                             category_months[]
  category_targets                                                            category_targets[]
  connections                                                                 connections[]
  credit_card_statements                                                      credit_card_statements[]
  financial_accounts                                                          financial_accounts[]
  goal_contributions                                                          goal_contributions[]
  goals                                                                       goals[]
  institutions                                                                institutions[]
  liabilities                                                                 liabilities[]
  merchants                                                                   merchants[]
  monthly_account_snapshots                                                   monthly_account_snapshots[]
  monthly_category_snapshots                                                  monthly_category_snapshots[]
  net_worth_snapshots                                                         net_worth_snapshots[]
  recurring_rules                                                             recurring_rules[]
  tags                                                                        tags[]
  transaction_splits                                                          transaction_splits[]
  transaction_tags                                                            transaction_tags[]
  transactions                                                                transactions[]
  transfer_links                                                              transfer_links[]
  user_preferences                                                            user_preferences?

  @@map("users")
  @@schema("app")
}

model Budget {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                   String                     @unique(map: "uq_budgets_user_default", where: raw("((is_default = true) AND (deleted_at IS NULL))")) @map("user_id") @db.Uuid
  name                     String
  currency                 String                     @default("CAD") @map("currency") @db.VarChar(3)
  isDefault                Boolean                    @default(false) @map("is_default")
  status                   budget_status              @default(active)
  createdAt                DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime                   @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt                DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  budget_assignment_events budget_assignment_events[]
  budget_months            budget_months[]
  user                     User                       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  categories               categories[]
  category_groups          category_groups[]
  transactions             transactions[]

  @@index([userId, status], map: "idx_budgets_user_status")
  @@map("budgets")
  @@schema("app")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model assets {
  id                      String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String     @db.Uuid
  name                    String
  type                    asset_type
  institution_name        String?
  currency                String     @default("CAD") @db.VarChar(3)
  quantity                Decimal?   @db.Decimal(18, 8)
  unit_cost_minor         BigInt?
  acquisition_value_minor BigInt?
  current_value_minor     BigInt
  valuation_date          DateTime?  @db.Date
  include_in_net_worth    Boolean    @default(true)
  is_manual               Boolean    @default(true)
  notes                   String?
  metadata                Json       @default("{}")
  created_at              DateTime   @default(now()) @db.Timestamptz(6)
  updated_at              DateTime   @default(now()) @db.Timestamptz(6)
  deleted_at              DateTime?  @db.Timestamptz(6)
  users                   User       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, type], map: "idx_assets_user_type")
  @@schema("app")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model auth_sessions {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String         @db.Uuid
  token_hash   String         @unique
  status       session_status @default(active)
  ip_address   String?        @db.Inet
  user_agent   String?
  expires_at   DateTime       @db.Timestamptz(6)
  last_seen_at DateTime?      @db.Timestamptz(6)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @db.Timestamptz(6)
  revoked_at   DateTime?      @db.Timestamptz(6)
  users        User           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_auth_sessions_expires_at")
  @@index([user_id, status], map: "idx_auth_sessions_user_status")
  @@schema("app")
}

